   ===================================================================== */
const STAGES = [
{ id:"calm", name:"Calm", sub:"Regulated baseline — no intervention needed",
  ac:"#1D9E75", acB:"#5DCAA5", bgTint:"rgba(29,158,117,0.14)",
  hrv:"72 ms", gsr:"1.1 µS", hr:"61 bpm", duration:"baseline",
  haptic:"No haptic alert — system stays silent",
  grammar:[["Shape","Single fluid sphere"],["Motion","0.3× — slow orbital drift"],["Colour","Cool teal-green"],["Density","Open, loose spacing"]],
  draw(ctx,t){
    const cx=100,cy=100; ctx.clearRect(0,0,200,200)
    const bg=ctx.createRadialGradient(cx,cy,8,cx,cy,90)
    bg.addColorStop(0,"rgba(29,158,117,0.10)"); bg.addColorStop(1,"rgba(0,0,0,0)")
    ctx.fillStyle=bg; ctx.beginPath(); ctx.arc(cx,cy,90,0,Math.PI*2); ctx.fill()
    for(let i=0;i<3;i++){
      const ph=t*0.25+i*Math.PI*2/3
      const px=cx+Math.cos(ph)*7, py=cy+Math.sin(ph)*7
      const g=ctx.createRadialGradient(px,py,0,px,py,60-i*7)
      g.addColorStop(0,"rgba(93,202,165,0.45)"); g.addColorStop(0.6,"rgba(29,158,117,0.18)"); g.addColorStop(1,"rgba(0,0,0,0)")
      ctx.fillStyle=g; ctx.beginPath(); ctx.arc(px,py,60-i*7,0,Math.PI*2); ctx.fill()
    }
    for(let i=0;i<6;i++){
      const a=t*0.18+i*Math.PI/3, d=48+Math.sin(t*0.35+i)*7
      const x=cx+Math.cos(a)*d, y=cy+Math.sin(a)*d
      ctx.beginPath(); ctx.arc(x,y,3.5+Math.sin(t*0.5+i)*1,0,Math.PI*2)
      ctx.fillStyle="rgba(93,202,165,0.55)"; ctx.fill()
    }
    ctx.beginPath(); ctx.arc(cx,cy,5+Math.sin(t*0.45)*1.5,0,Math.PI*2)
    ctx.fillStyle="rgba(159,225,203,0.85)"; ctx.fill()
  }},
{ id:"tension", name:"Tension", sub:"Early activation — first visible signal",
  ac:"#185FA5", acB:"#6FB0EA", bgTint:"rgba(111,176,234,0.14)",
