/* =====================================================================
   PROJECTION SHEET — mirror -> entrain regulation demo
   ===================================================================== */
const STARTS = {
  tension:{label:"Tension",ac:"#185FA5",acB:"#6FB0EA",hrvLo:54,hrvHi:72,hrLo:73,hrHi:61,breathLo:14,breathHi:6,
    col0:[133,183,235],colMid:[110,180,200],col1:[93,202,165],spread0:0.25,spread1:0,speed0:1.0,speed1:0.3,dur:14},
  strain:{label:"Strain",ac:"#BA7517",acB:"#F2B341",hrvLo:40,hrvHi:72,hrLo:85,hrHi:61,breathLo:17,breathHi:6,
    col0:[242,166,35],colMid:[170,180,140],col1:[93,202,165],spread0:0.55,spread1:0,speed0:1.4,speed1:0.3,dur:18},
  overload:{label:"Overload",ac:"#A32D2D",acB:"#F16E68",hrvLo:24,hrvHi:72,hrLo:99,hrHi:61,breathLo:20,breathHi:6,
    col0:[226,75,74],colMid:[200,140,90],col1:[93,202,165],spread0:0.9,spread1:0,speed0:2.0,speed1:0.3,dur:24},
}
let activeKey="strain", playing=false, raf=null, pt=0, startTime=null
const TOTAL_MIRROR=3

function lerp(a,b,p){return a+(b-a)*p}
function lerpCol(c0,c1,p){return [lerp(c0[0],c1[0],p),lerp(c0[1],c1[1],p),lerp(c0[2],c1[2],p)]}
function easeInOut(p){return p<0.5?2*p*p:1-Math.pow(-2*p+2,2)/2}

const sheetPills = document.getElementById("sheet-pills")
Object.entries(STARTS).forEach(([key,s])=>{
  const b=document.createElement("button")
  b.className="stage-pill"+(key===activeKey?" active":"")
  b.textContent=s.label
  b.style.setProperty("--pc", s.acB)
  if(key===activeKey){ b.style.background=s.acB; b.style.borderColor=s.acB; b.style.color="#08110D" }
  b.onclick=()=>{ activeKey=key; resetProj(); buildPills() }
  sheetPills.appendChild(b)
})
function buildPills(){
  sheetPills.querySelectorAll("button").forEach((b,i)=>{
    const key=Object.keys(STARTS)[i], s=STARTS[key]
    if(key===activeKey){ b.style.background=s.acB; b.style.borderColor=s.acB; b.style.color="#08110D" }
    else { b.style.background="var(--surface)"; b.style.borderColor="var(--hair)"; b.style.color="var(--text-soft)" }
  })
}

function projDraw(ctx,p){
  const cx=100,cy=100
  const s=STARTS[activeKey]
  ctx.clearRect(0,0,200,200)
  const spread=lerp(s.spread0,s.spread1,p)
  const speed=lerp(s.speed0,s.speed1,p)
  let col
  if(p<0.5) col=lerpCol(s.col0,s.colMid,p*2)
  else col=lerpCol(s.colMid,s.col1,(p-0.5)*2)
  const colStr=`rgba(${Math.round(col[0])},${Math.round(col[1])},${Math.round(col[2])},`
  const bg=ctx.createRadialGradient(cx,cy,8,cx,cy,92)
  bg.addColorStop(0,colStr+"0.14)"); bg.addColorStop(1,"rgba(0,0,0,0)")
  ctx.fillStyle=bg; ctx.beginPath(); ctx.arc(cx,cy,92,0,Math.PI*2); ctx.fill()
  const N=Math.round(lerp(24,6,p))
  for(let i=0;i<N;i++){
    const base=i/N*Math.PI*2
    const jitter=Math.sin(pt*(1.5+speed)+i*1.6)*spread
    const r=lerp(46,50,p)+Math.sin(pt*(0.8+speed*0.6)+i*0.7)*lerp(20,8,p)
    const x=cx+Math.cos(base+jitter)*r, y=cy+Math.sin(base+jitter)*r
    const size=lerp(2.8,4.2,p)+Math.sin(pt*(1+speed)+i)*0.8
    ctx.beginPath(); ctx.arc(x,y,size,0,Math.PI*2)
    ctx.fillStyle=colStr+(0.55+0.2*p)+")"; ctx.fill()
  }
  const coreR=lerp(15,20,p)+Math.sin(pt*(0.5+speed*0.5))*lerp(6,2,p)
  const core=ctx.createRadialGradient(cx,cy,0,cx,cy,coreR)
  core.addColorStop(0,colStr+"0.9)"); core.addColorStop(1,colStr+"0)")
  ctx.fillStyle=core; ctx.beginPath(); ctx.arc(cx,cy,coreR,0,Math.PI*2); ctx.fill()
}
let currentP = 0
registerCanvas(document.getElementById("proj-canvas"), (ctx)=>{ pt+=0.016; projDraw(ctx,currentP) })

function setPhaseDetail(phase){
  const d=document.getElementById("phase-card")
  const s=STARTS[activeKey]
  if(phase==="ready"){
    d.innerHTML=`<div class="pt">Ready to begin</div><div class="pd">Press play to see the projection mirror the current "${s.label.toLowerCase()}" state, then gradually guide it toward calm.</div>`
  } else if(phase==="mirror"){
    d.innerHTML=`<div class="pt" style="color:${s.acB}">Phase 1 — Mirror</div><div class="pd">The form shows the current state exactly as detected, unaltered. This acknowledgment matters — the system validates what's actually happening before attempting any change.</div>`
  } else if(phase==="entrain"){
    d.innerHTML=`<div class="pt" style="color:var(--calm-b)">Phase 2 — Entrain</div><div class="pd">Rhythm, colour and shape glide toward calm in graduated steps — never a hard cut. Your breath naturally follows the slowing pace rather than being told to slow down.</div>`
  } else if(phase==="done"){
    d.innerHTML=`<div class="pt" style="color:var(--calm-b)">Regulation complete</div><div class="pd">The form has settled into the calm sphere. HRV has recovered and breath pace has slowed to 5–6 breaths per minute. Projection now fades to ambient.</div>`
  }
}

function resetProj(){
  playing=false; if(raf) cancelAnimationFrame(raf)
  startTime=null; currentP=0
  document.getElementById("proj-play").textContent="Play regulation sequence"
  const pill=document.getElementById("phase-pill")
  pill.textContent="Ready"; pill.style.background="var(--surface)"; pill.style.color="var(--text-soft)"
  document.getElementById("proj-fill").style.width="0%"
  document.getElementById("breath-cue").textContent=""
  const s=STARTS[activeKey]
  document.getElementById("live-hrv").textContent=s.hrvLo+" ms"
  document.getElementById("live-hr").textContent=s.hrLo+" bpm"
  document.getElementById("live-breath").textContent=s.breathLo+"/min"
  setPhaseDetail("ready")
}

function projFrame(now){
  if(!startTime) startTime=now
  const elapsed=(now-startTime)/1000
  const s=STARTS[activeKey]
  const totalDur=s.dur
  const pill=document.getElementById("phase-pill")
  const cue=document.getElementById("breath-cue")

  if(elapsed<TOTAL_MIRROR){
    pill.textContent="Mirroring "+s.label.toLowerCase()
    pill.style.background=s.acB+"26"; pill.style.color=s.acB
    setPhaseDetail("mirror"); cue.textContent=""; currentP=0
  } else if(elapsed<totalDur){
    const p=easeInOut((elapsed-TOTAL_MIRROR)/(totalDur-TOTAL_MIRROR))
    pill.textContent="Entraining toward calm"
    pill.style.background="rgba(93,202,165,0.16)"; pill.style.color="var(--calm-b)"
    setPhaseDetail("entrain")
    const breathPace=lerp(s.breathLo,s.breathHi,p)
    const cyclePos=(elapsed*(breathPace/60))%1
    const breathingIn = cyclePos<0.5
    cue.textContent = breathingIn ? "Breathe in ·" : "Breathe out ·"
    cue.classList.toggle("in", breathingIn)
    document.getElementById("live-hrv").textContent=Math.round(lerp(s.hrvLo,s.hrvHi,p))+" ms"
    document.getElementById("live-hr").textContent=Math.round(lerp(s.hrLo,s.hrHi,p))+" bpm"
    document.getElementById("live-breath").textContent=Math.round(breathPace)+"/min"
    currentP=p
  } else {
    pill.textContent="Calm — ambient"
    pill.style.background="rgba(93,202,165,0.16)"; pill.style.color="var(--calm-b)"
    setPhaseDetail("done")
    cue.textContent="5–6 breaths / min"; cue.classList.remove("in")
    document.getElementById("live-hrv").textContent=s.hrvHi+" ms"
    document.getElementById("live-hr").textContent=s.hrHi+" bpm"
    document.getElementById("live-breath").textContent=s.breathHi+"/min"
    currentP=1
    document.getElementById("proj-fill").style.width="100%"
    document.getElementById("proj-play").textContent="Play again"
    playing=false
    return
  }
  document.getElementById("proj-fill").style.width=Math.min(100,(elapsed/totalDur)*100)+"%"
  document.getElementById("proj-fill").style.background=s.acB
  raf=requestAnimationFrame(projFrame)
}

document.getElementById("proj-play").onclick=()=>{
  if(playing) return
  playing=true; startTime=null
  document.getElementById("proj-play").textContent="Playing..."
  raf=requestAnimationFrame(projFrame)
}
document.getElementById("proj-reset").onclick=resetProj

/* open / close sheet */
const sheet=document.getElementById("sheet")
document.getElementById("open-regulation").addEventListener("click", ()=>{
  activeKey="strain"; buildPills(); resetProj()
  sheet.classList.add("open")
})
document.getElementById("sheet-back").addEventListener("click", ()=>{
  sheet.classList.remove("open"); resetProj()
})
resetProj()
</script>
</body>
</html>
