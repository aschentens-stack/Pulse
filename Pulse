  haptic:"Single soft pulse — easy to dismiss",
  grammar:[["Shape","Sphere begins rippling"],["Motion","0.6× — noticeably more active"],["Colour","Teal shifting to blue"],["Density","Slight contraction, 15%"]],
  draw(ctx,t){
    const cx=100,cy=100; ctx.clearRect(0,0,200,200)
    const bg=ctx.createRadialGradient(cx,cy,8,cx,cy,90)
    bg.addColorStop(0,"rgba(55,138,221,0.10)"); bg.addColorStop(1,"rgba(0,0,0,0)")
    ctx.fillStyle=bg; ctx.beginPath(); ctx.arc(cx,cy,90,0,Math.PI*2); ctx.fill()
    const N=16
    for(let i=0;i<N;i++){
      const a=i/N*Math.PI*2, ripple=Math.sin(t*1.2+i*0.8)*6, r=42+ripple
      const x=cx+Math.cos(a)*r, y=cy+Math.sin(a)*r
      ctx.beginPath(); ctx.arc(x,y,3+Math.sin(t*0.8+i)*0.8,0,Math.PI*2)
      ctx.fillStyle="rgba(133,183,235,0.6)"; ctx.fill()
    }
    const core=ctx.createRadialGradient(cx,cy,0,cx,cy,38)
    core.addColorStop(0,"rgba(133,183,235,0.35)"); core.addColorStop(1,"rgba(55,138,221,0.05)")
    ctx.fillStyle=core; ctx.beginPath(); ctx.arc(cx,cy,38,0,Math.PI*2); ctx.fill()
    ctx.beginPath(); ctx.arc(cx,cy,6+Math.sin(t*0.7)*1.5,0,Math.PI*2)
    ctx.fillStyle="rgba(190,215,245,0.85)"; ctx.fill()
  }},
{ id:"strain", name:"Strain", sub:"Sustained activation — pattern now persistent",
  ac:"#BA7517", acB:"#F2B341", bgTint:"rgba(242,179,65,0.14)",
  hrv:"40 ms", gsr:"3.6 µS", hr:"85 bpm", duration:"5+ min",
  haptic:"Double pulse, repeated every 3 min",
  grammar:[["Shape","Fragmenting, 4–6 pieces"],["Motion","1.0× — visible turbulence"],["Colour","Amber-orange"],["Density","Particles pulling inward"]],
  draw(ctx,t){
    const cx=100,cy=100; ctx.clearRect(0,0,200,200)
    const bg=ctx.createRadialGradient(cx,cy,8,cx,cy,92)
    bg.addColorStop(0,"rgba(239,159,39,0.12)"); bg.addColorStop(1,"rgba(0,0,0,0)")
    ctx.fillStyle=bg; ctx.beginPath(); ctx.arc(cx,cy,92,0,Math.PI*2); ctx.fill()
    const N=22
    for(let i=0;i<N;i++){
      const base=i/N*Math.PI*2, jitter=Math.sin(t*1.3+i*1.6)*0.25, r=35+Math.sin(t*1.0+i*0.7)*14
      const x=cx+Math.cos(base+jitter)*r, y=cy+Math.sin(base+jitter)*r
      const s=2.8+Math.sin(t*1.1+i)*0.9
      ctx.beginPath(); ctx.arc(x,y,s,0,Math.PI*2)
      ctx.fillStyle="rgba(242,166,35,0.7)"; ctx.fill()
    }
    const core=ctx.createRadialGradient(cx,cy,0,cx,cy,30+Math.sin(t*1.3)*4)
    core.addColorStop(0,"rgba(252,217,140,0.7)"); core.addColorStop(1,"rgba(186,117,23,0.05)")
    ctx.fillStyle=core; ctx.beginPath(); ctx.arc(cx,cy,30+Math.sin(t*1.3)*4,0,Math.PI*2); ctx.fill()
  }},
{ id:"overload", name:"Overload", sub:"Critical activation — system requests intervention",
  ac:"#A32D2D", acB:"#F16E68", bgTint:"rgba(241,110,104,0.14)",
  hrv:"24 ms", gsr:"5.8 µS", hr:"99 bpm", duration:"10+ min",
  haptic:"Firm sustained vibration — hard to ignore",
  grammar:[["Shape","Sharp fragmenting shards"],["Motion","1.6× — fast, erratic"],["Colour","Deep red-crimson"],["Density","Explosive, breaking apart"]],
  draw(ctx,t){
    const cx=100,cy=100; ctx.clearRect(0,0,200,200)
    const bg=ctx.createRadialGradient(cx,cy,5,cx,cy,92)
    bg.addColorStop(0,"rgba(162,45,45,0.16)"); bg.addColorStop(1,"rgba(0,0,0,0)")
    ctx.fillStyle=bg; ctx.beginPath(); ctx.arc(cx,cy,92,0,Math.PI*2); ctx.fill()
    const N=16
    for(let i=0;i<N;i++){
      const base=i/N*Math.PI*2+t*2.4, jitter=Math.sin(t*3+i*1.7)*0.5
      const r=26+Math.abs(Math.sin(t*2+i*1.2))*44, tipR=r+9
      const tx=cx+Math.cos(base+jitter)*tipR, ty=cy+Math.sin(base+jitter)*tipR
      const l1x=cx+Math.cos(base+jitter-0.22)*r*0.65, l1y=cy+Math.sin(base+jitter-0.22)*r*0.65
      const l2x=cx+Math.cos(base+jitter+0.22)*r*0.65, l2y=cy+Math.sin(base+jitter+0.22)*r*0.65
      ctx.beginPath(); ctx.moveTo(l1x,l1y); ctx.lineTo(tx,ty); ctx.lineTo(l2x,l2y); ctx.closePath()
      ctx.fillStyle=Math.sin(t*1.4+i)>0.2?"rgba(226,75,74,0.85)":"rgba(179,58,58,0.7)"
      ctx.fill()
    }
    const core=ctx.createRadialGradient(cx,cy,0,cx,cy,14+Math.sin(t*2.6)*5)
    core.addColorStop(0,"rgba(255,200,200,0.9)"); core.addColorStop(0.5,"rgba(226,75,74,0.75)"); core.addColorStop(1,"rgba(162,45,45,0)")
    ctx.fillStyle=core; ctx.beginPath(); ctx.arc(cx,cy,14+Math.sin(t*2.6)*5,0,Math.PI*2); ctx.fill()
  }},
{ id:"burnout", name:"Burnout", sub:"Chronic depletion — distinct from acute stress",
  ac:"#534AB7", acB:"#9C94EE", bgTint:"rgba(156,148,238,0.14)",
  hrv:"<20 ms, flat", gsr:"chronically low", hr:"blunted", duration:"days–weeks",
  haptic:"No urgent alert — slow, low-intensity pulse only",
  grammar:[["Shape","Heavy, sagging cloud"],["Motion","0.15× — near-stillness"],["Colour","Muted grey-violet"],["Density","Dissolving edges"]],
  draw(ctx,t){
    const cx=100,cy=108; ctx.clearRect(0,0,200,200)
    const bg=ctx.createRadialGradient(cx,cy,5,cx,cy,92)
    bg.addColorStop(0,"rgba(83,74,183,0.09)"); bg.addColorStop(1,"rgba(0,0,0,0)")
    ctx.fillStyle=bg; ctx.beginPath(); ctx.arc(cx,cy,92,0,Math.PI*2); ctx.fill()
    for(let i=0;i<11;i++){
      const a=i/11*Math.PI*2+t*0.05, sag=7+Math.sin(t*0.1)*2.5
      const rx=42+Math.sin(a*2+t*0.08)*7, ry=30-Math.sin(a+t*0.06)*4+sag
      const x=cx+Math.cos(a)*34, y=cy+Math.sin(a)*24+sag
      const alph=0.22+Math.sin(t*0.12+i)*0.06
      ctx.beginPath(); ctx.ellipse(x,y,rx,ry,a*0.25+t*0.04,0,Math.PI*2)
      ctx.fillStyle=`rgba(127,119,221,${alph})`; ctx.fill()
    }
    for(let i=0;i<4;i++){
      const a=t*0.04+i*Math.PI*0.5
      const x=cx+Math.cos(a)*16, y=cy+Math.sin(a)*12+Math.sin(t*0.14+i)*3
      ctx.beginPath(); ctx.arc(x,y,3.5+Math.sin(t*0.16+i)*1,0,Math.PI*2)
      ctx.fillStyle="rgba(175,169,236,0.5)"; ctx.fill()
    }
  }},
];
const byId = Object.fromEntries(STAGES.map(s=>[s.id,s]))

/* =====================================================================
   Canvas registry — single rAF loop, only animates visible canvases
   ===================================================================== */
const registry = []
function registerCanvas(canvas, drawFn){
  const ctx = canvas.getContext("2d")
  const entry = {canvas, ctx, drawFn, t: Math.random()*10}
  registry.push(entry)
  return entry
}
function loop(){
  registry.forEach(e=>{
    if(e.canvas.offsetParent !== null){ e.t += 0.016; e.drawFn(e.ctx, e.t) }
  })
  requestAnimationFrame(loop)
}
requestAnimationFrame(loop)

/* =====================================================================
   Navigation
   ===================================================================== */
